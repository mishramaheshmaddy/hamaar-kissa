{
  "expo": {
    "name": "Hamaar Kissa",
    "slug": "hamaar-kissa",
    "version": "1.0.19",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "hamaarkissa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8530A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haamarkissa.app"
    },
    "android": {
      "package": "com.haamarkissa.app",
      "versionCode": 21,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#E8530A"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hamaar-kissa-api.onrender.com",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "hamaar-kissa-api.onrender.com",
              "pathPrefix": "/content"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/b3606548-d7c0-43ee-9c4f-8b83b34324c4"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b3606548-d7c0-43ee-9c4f-8b83b34324c4"
      }
    },
    "owner": "maheshmishra"
  }
}
